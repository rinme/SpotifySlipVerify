# MongoDB Configuration (Optional - will use SQLite if not provided)
# MONGODB_URI=mongodb://localhost:27017/slipverify

# Authentication Secret (Required)
# Generate using: openssl rand -base64 32
AUTH_SECRET=your-secret-key-here-change-in-production

# Application URL
PUBLIC_APP_URL=http://localhost:4321

# SlipOK API Configuration (Required for slip verification)
# Get your credentials at https://slipok.com
SLIPOK_BRANCH_ID=your-branch-id
SLIPOK_API_KEY=your-api-key
