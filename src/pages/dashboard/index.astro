---
import DashboardLayout from "../../layouts/DashboardLayout.astro";

const user = Astro.locals.user;
---

<DashboardLayout title="Dashboard" user={user}>
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Welcome back, {user.name}!</h1>
      <p class="mt-1 text-gray-600">Here's an overview of your payment history.</p>
    </div>

    <!-- Financial Overview Cards -->
    <div class="grid gap-6 md:grid-cols-3">
      <div class="rounded-lg bg-white p-6 shadow">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Monthly Total</p>
            <p class="mt-2 text-3xl font-bold text-gray-900" id="monthly-total">฿0.00</p>
            <p class="mt-1 text-xs text-gray-500">Current month</p>
          </div>
          <div class="rounded-full bg-blue-100 p-3">
            <svg class="h-8 w-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>
      </div>

      <div class="rounded-lg bg-white p-6 shadow">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Yearly Total</p>
            <p class="mt-2 text-3xl font-bold text-gray-900" id="yearly-total">฿0.00</p>
            <p class="mt-1 text-xs text-gray-500">Current year</p>
          </div>
          <div class="rounded-full bg-green-100 p-3">
            <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
        </div>
      </div>

      <div class="rounded-lg bg-white p-6 shadow">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">All Time Total</p>
            <p class="mt-2 text-3xl font-bold text-gray-900" id="total">฿0.00</p>
            <p class="mt-1 text-xs text-gray-500">Lifetime payments</p>
          </div>
          <div class="rounded-full bg-purple-100 p-3">
            <svg class="h-8 w-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Slip Verification Section -->
    <div class="rounded-lg bg-white p-6 shadow">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">Verify Payment Slip</h2>
      <p class="mb-4 text-sm text-gray-600">Upload an image of your payment slip. The QR code will be automatically scanned and verified.</p>

      <!-- Upload Area -->
      <div
        id="drop-zone"
        class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center transition hover:border-indigo-500 cursor-pointer"
      >
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        <p class="mt-4 text-sm text-gray-600">
          <span class="font-semibold text-indigo-600">Click to upload</span> or drag and drop
        </p>
        <p class="mt-1 text-xs text-gray-500">PNG, JPG up to 10MB - QR code will be auto-detected</p>
      </div>

      <input type="file" id="file-input" class="hidden" accept="image/*" />

      <!-- Image Preview -->
      <div id="image-preview" class="mt-4 hidden">
        <div class="relative rounded-lg overflow-hidden bg-gray-100">
          <img id="preview-img" class="max-h-64 mx-auto" alt="Slip preview" />
          <button
            id="remove-image"
            class="absolute top-2 right-2 bg-red-500 text-white rounded-full p-1 hover:bg-red-600"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </button>
        </div>

        <div id="scan-status" class="mt-3 text-center">
          <div id="scanning" class="hidden">
            <div class="inline-flex items-center gap-2 text-indigo-600">
              <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              <span>Scanning QR code...</span>
            </div>
          </div>
          <div id="qr-found" class="hidden text-green-600 font-medium">
            ✓ QR Code detected
          </div>
          <div id="qr-not-found" class="hidden text-red-600">
            ✗ No QR code found. Please upload a clearer image.
          </div>
        </div>

        <button
          id="verify-btn"
          disabled
          class="mt-4 w-full rounded-lg bg-indigo-600 px-4 py-2 text-white font-semibold shadow-md transition hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Verify Slip
        </button>
      </div>

      <div id="verify-status" class="mt-4 hidden rounded-md p-3 text-sm"></div>

      <!-- Verification Result -->
      <div id="verify-result" class="mt-4 hidden rounded-lg border border-green-200 bg-green-50 p-4">
        <h3 class="font-semibold text-green-800 mb-2">✓ Slip Verified Successfully</h3>
        <div class="grid grid-cols-2 gap-2 text-sm">
          <div class="text-gray-600">Amount:</div>
          <div class="font-medium text-gray-900" id="result-amount"></div>
          <div class="text-gray-600">Transaction Ref:</div>
          <div class="font-medium text-gray-900" id="result-ref"></div>
          <div class="text-gray-600">From:</div>
          <div class="font-medium text-gray-900" id="result-sender"></div>
          <div class="text-gray-600">To:</div>
          <div class="font-medium text-gray-900" id="result-receiver"></div>
          <div class="text-gray-600">Date/Time:</div>
          <div class="font-medium text-gray-900" id="result-datetime"></div>
        </div>
      </div>

      <!-- Hidden canvas for QR processing -->
      <canvas id="qr-canvas" class="hidden"></canvas>
    </div>

    <!-- Recent Payments -->
    <div class="rounded-lg bg-white p-6 shadow">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">Recent Payments</h2>
      <div id="payments-list" class="space-y-3">
        <p class="text-sm text-gray-500 text-center py-8">No payments yet. Upload your first slip above!</p>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import jsQR from 'jsqr';

  // DOM Elements
  const dropZone = document.getElementById('drop-zone') as HTMLDivElement;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const imagePreview = document.getElementById('image-preview') as HTMLDivElement;
  const previewImg = document.getElementById('preview-img') as HTMLImageElement;
  const removeImageBtn = document.getElementById('remove-image') as HTMLButtonElement;
  const verifyBtn = document.getElementById('verify-btn') as HTMLButtonElement;
  const verifyStatus = document.getElementById('verify-status') as HTMLDivElement;
  const verifyResult = document.getElementById('verify-result') as HTMLDivElement;
  const qrCanvas = document.getElementById('qr-canvas') as HTMLCanvasElement;
  const scanningEl = document.getElementById('scanning') as HTMLDivElement;
  const qrFoundEl = document.getElementById('qr-found') as HTMLDivElement;
  const qrNotFoundEl = document.getElementById('qr-not-found') as HTMLDivElement;

  let extractedQRData: string | null = null;

  // File drop/select handlers
  dropZone.addEventListener('click', () => fileInput.click());

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-indigo-500', 'bg-indigo-50');
  });

  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-indigo-500', 'bg-indigo-50');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-indigo-500', 'bg-indigo-50');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) {
      handleImageFile(files[0]);
    }
  });

  fileInput.addEventListener('change', (e) => {
    const files = (e.target as HTMLInputElement).files;
    if (files && files.length > 0) {
      handleImageFile(files[0]);
    }
  });

  removeImageBtn.addEventListener('click', resetUpload);

  function resetUpload() {
    extractedQRData = null;
    fileInput.value = '';
    imagePreview.classList.add('hidden');
    dropZone.classList.remove('hidden');
    verifyBtn.disabled = true;
    verifyStatus.classList.add('hidden');
    verifyResult.classList.add('hidden');
    scanningEl.classList.add('hidden');
    qrFoundEl.classList.add('hidden');
    qrNotFoundEl.classList.add('hidden');
  }

  async function handleImageFile(file: File) {
    if (!file.type.startsWith('image/')) {
      showError('Please upload an image file');
      return;
    }

    // Show preview
    const reader = new FileReader();
    reader.onload = (e) => {
      previewImg.src = e.target?.result as string;
      dropZone.classList.add('hidden');
      imagePreview.classList.remove('hidden');
      scanQRCode(e.target?.result as string);
    };
    reader.readAsDataURL(file);
  }

  async function scanQRCode(imageDataUrl: string) {
    scanningEl.classList.remove('hidden');
    qrFoundEl.classList.add('hidden');
    qrNotFoundEl.classList.add('hidden');
    verifyBtn.disabled = true;

    const img = new Image();
    img.onload = () => {
      const ctx = qrCanvas.getContext('2d')!;
      qrCanvas.width = img.width;
      qrCanvas.height = img.height;
      ctx.drawImage(img, 0, 0);

      const imageData = ctx.getImageData(0, 0, qrCanvas.width, qrCanvas.height);
      const qrCode = jsQR(imageData.data, imageData.width, imageData.height);

      scanningEl.classList.add('hidden');

      if (qrCode && qrCode.data) {
        extractedQRData = qrCode.data;
        qrFoundEl.classList.remove('hidden');
        verifyBtn.disabled = false;
      } else {
        qrNotFoundEl.classList.remove('hidden');
        extractedQRData = null;
      }
    };
    img.src = imageDataUrl;
  }

  function showError(message: string) {
    verifyStatus.textContent = message;
    verifyStatus.classList.remove('hidden', 'bg-green-50', 'text-green-700');
    verifyStatus.classList.add('bg-red-50', 'text-red-700');
  }

  // Verify button handler
  verifyBtn.addEventListener('click', async () => {
    if (!extractedQRData) return;

    verifyBtn.disabled = true;
    verifyBtn.textContent = 'Verifying...';
    verifyStatus.classList.add('hidden');
    verifyResult.classList.add('hidden');

    try {
      const response = await fetch('/api/slip/verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ qrData: extractedQRData }),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        const payment = result.payment;
        document.getElementById('result-amount')!.textContent = `฿${payment.amount.toFixed(2)}`;
        document.getElementById('result-ref')!.textContent = payment.transRef;
        document.getElementById('result-sender')!.textContent = `${payment.senderName} (${payment.sendingBank})`;
        document.getElementById('result-receiver')!.textContent = `${payment.receiverName} (${payment.receivingBank})`;
        document.getElementById('result-datetime')!.textContent = `${payment.transDate} ${payment.transTime}`;

        verifyResult.classList.remove('hidden');
        
        // Reset after success
        setTimeout(() => {
          resetUpload();
          loadFinancialData();
          loadRecentPayments();
        }, 3000);
      } else {
        showError(result.error || 'Failed to verify slip');
      }
    } catch (error) {
      console.error('Verification error:', error);
      showError('An error occurred. Please try again.');
    } finally {
      verifyBtn.disabled = false;
      verifyBtn.textContent = 'Verify Slip';
    }
  });

  // Load financial data
  async function loadFinancialData() {
    try {
      const response = await fetch('/api/payments/summary');
      if (response.ok) {
        const data = await response.json();
        document.getElementById('monthly-total')!.textContent = `฿${data.monthly.toFixed(2)}`;
        document.getElementById('yearly-total')!.textContent = `฿${data.yearly.toFixed(2)}`;
        document.getElementById('total')!.textContent = `฿${data.total.toFixed(2)}`;
      }
    } catch (error) {
      console.error('Failed to load financial data:', error);
    }
  }

  // Load recent payments
  async function loadRecentPayments() {
    try {
      const response = await fetch('/api/payments/recent');
      if (response.ok) {
        const payments = await response.json();
        const paymentsList = document.getElementById('payments-list')!;

        if (payments.length === 0) {
          paymentsList.innerHTML = '<p class="text-sm text-gray-500 text-center py-8">No payments yet. Upload your first slip above!</p>';
          return;
        }

        paymentsList.innerHTML = payments.map((p: any) => `
          <div class="flex items-center justify-between rounded-lg bg-gray-50 p-4">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-green-100">
                <svg class="h-5 w-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-900">฿${p.amount.toFixed(2)}</p>
                <p class="text-xs text-gray-500">${p.transDate || new Date(p.createdAt).toLocaleDateString()}</p>
              </div>
            </div>
            <div class="text-right">
              <p class="text-xs text-gray-500">${p.sendingBank || ''} → ${p.receivingBank || ''}</p>
              <p class="text-xs text-gray-400">${p.transRef || ''}</p>
            </div>
          </div>
        `).join('');
      }
    } catch (error) {
      console.error('Failed to load recent payments:', error);
    }
  }

  // Load on page load
  loadFinancialData();
  loadRecentPayments();
</script>
